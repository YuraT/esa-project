# ArcGIS API Configuration
# Get your API key from: https://developers.arcgis.com/api-keys/
ARCGIS_API_KEY=your_arcgis_api_key_here
NEXT_PUBLIC_ARCGIS_API_KEY=your_arcgis_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
# Add other environment variables as needed
// TODO: for some reason the blt website does not use a valid certificate at this moment,
// remove this when that gets resolved
NODE_TLS_REJECT_UNAUTHORIZED=0
